# ==========================================================
# CC-BOMGenerator 环境变量模板
# 用法：复制本文件为 .env，填入你本机的真实值。
#   cp .env.example .env
# .env 已在 .gitignore 中，绝不入库（含密码/密钥）。
# 每位开发者各自维护本地 .env，互不影响。
# ==========================================================

# ===== MySQL 连接（本地开发）=====
# 字符集务必 utf8mb4（合同数据为中文）。
# 建库 SQL（在 mysql 里执行一次）：
#   CREATE DATABASE cc_bom_generator CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cc_bom_generator

# ===== 外部大模型（Gemini）=====
# API 直连模式用；手动模式可不填
GEMINI_API_KEY=

# ===== 应用 =====
APP_ENV=dev
